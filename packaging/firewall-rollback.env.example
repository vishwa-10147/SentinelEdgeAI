## Example env file for sentinel-firewall-rollback guard
# Copy to /etc/sentinel/firewall-rollback.env and edit values as needed.

# Backend API base URL
API_URL=http://127.0.0.1:9000

# Optional API key for dashboard API
#API_KEY=your_dashboard_api_key_here

# Minimum uptime (seconds) required to consider the node healthy
MIN_UPTIME_SECONDS=30

# Timeout for health request (seconds)
HEALTH_TIMEOUT=5
